// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameType {
  BALLOON_POP
  BIRTHDAY_CAKE
  GIFT_BOX
  SPIN_WHEEL
  STICKY_NOTE
  REWARD_DISPLAY
  MOOD_RATING
  MEMORY_COLLAGE
  DART_GAME
  FISHING_GAME
  LUCKY_DRAW
  EGG_SHOOTER
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cards BirthdayCard[]

  @@map("users")
}

model BirthdayCard {
  id                  String   @id @default(cuid())
  slug                String   @unique
  recipientName       String
  userId              String
  themeId             String
  backgroundMusicUrl  String?
  publishedAt         DateTime @default(now())
  viewCount           Int      @default(0)
  isTemplate          Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme Theme          @relation(fields: [themeId], references: [id])
  games GameInstance[]
  views CardView[]

  @@map("birthday_cards")
}

model GameInstance {
  id       String   @id @default(cuid())
  cardId   String
  gameType GameType
  order    Int
  config   Json
  createdAt DateTime @default(now())

  card BirthdayCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("game_instances")
}

model Theme {
  id              String @id @default(cuid())
  name            String
  primaryColor    String
  secondaryColor  String
  backgroundColor String
  accentColor     String
  gradient        String

  cards BirthdayCard[]

  @@map("themes")
}

model CardView {
  id        String   @id @default(cuid())
  cardId    String
  viewedAt  DateTime @default(now())
  ipAddress String?

  card BirthdayCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("card_views")
}
